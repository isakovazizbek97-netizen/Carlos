class User:
    count = 0
   
    def __init__(self, name, login, password, rating=0):
        self._name = name
        self._login = login
        self._password = password
        self._rating = rating
        User.count += 1
   
    @property
    def name(self):
        return self._name
   
    @name.setter
    def name(self, value):
        self._name = value
   
    @property
    def login(self):
        return self._login
   
    @login.setter
    def login(self, value):
        print("Невозможно изменить логин!")
   
    @property
    def password(self):
        return '*' * len(self._password)
   
    @password.setter
    def password(self, value):
        self._password = value
   
    @property
    def rating(self):
        return self._rating
   
    @rating.setter
    def rating(self, value):
        self._rating = value
   
    def show_info(self):
        print(f"Name: {self._name}, Login: {self._login}")
   
    def __lt__(self, other):
        return self._rating < other._rating
   
    def __eq__(self, other):
        return self._rating == other._rating


class SuperUser(User):
    count = 0
   
    def __init__(self, name, login, password, role, rating=0):
        super().__init__(name, login, password, rating)
        self._role = role
        SuperUser.count += 1
        User.count -= 1
   
    @property
    def role(self):
        return self._role
   
    @role.setter
    def role(self, value):
        self._role = value
   
    def show_info(self):
        print(f"Name: {self._name}, Login: {self._login}, Role: {self._role}")
   
    def __getattr__(self, name):
        if name == 'grade':
            print("Неизвестное свойство grade")
            return None
        raise AttributeError(f"'SuperUser' object has no attribute '{name}'")
   
    def __setattr__(self, name, value):
        if name == 'grade':
            print("Неизвестное свойство grade")
        else:
            super().__setattr__(name, value)


